# Postgres connection string
DB_URL=postgres://user:password@host:5432/wedding

# Origin allowed by CORS (your deployed frontend URL)
FRONTEND_URL=http://localhost:5173

# Shared admin password for the management/login page
ADMIN_PASSWORD=change-me

# Secret used to sign session tokens (use a long random value)
SESSION_SECRET=change-me-to-a-long-random-string

# Port to listen on (PaaS platforms inject this automatically)
PORT=8080
